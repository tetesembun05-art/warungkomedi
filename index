<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Warung Komedi - Official App</title>
  <style>
    /* DESAIN KHAS WARUNG KOPI */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { 
      background: #4e342e; 
      background-image: url('https://www.transparenttextures.com/patterns/wood-pattern.png');
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      padding: 15px; color: #3e2723;
    }
    .container {
      max-width: 480px; margin: 0 auto; background: #efebe9;
      border: 8px solid #3e2723; border-radius: 15px; padding: 20px;
      box-shadow: 12px 12px 0px rgba(0,0,0,0.3);
    }
    h1 { text-align: center; font-size: 32px; text-shadow: 2px 2px #d7ccc8; margin-bottom: 5px; }
    .subtitle { text-align: center; font-size: 14px; margin-bottom: 20px; font-style: italic; }

    /* BOX INPUT TOKEN (ANTI SCAN GITHUB) */
    .token-box { background: #d7ccc8; padding: 15px; border-radius: 10px; margin-bottom: 20px; border: 2px dashed #5d4037; }
    input[type="password"], select { width: 100%; padding: 12px; margin-top: 8px; border-radius: 8px; border: 2px solid #5d4037; font-size: 14px; }

    /* CARD CERITA */
    .card { background: #fff; padding: 15px; border-radius: 12px; margin-bottom: 15px; box-shadow: 4px 4px 0px #bcaaa4; }
    .btn { 
      width: 100%; padding: 15px; border: none; border-radius: 10px; font-weight: bold; font-size: 16px;
      cursor: pointer; transition: 0.2s; color: white; background: #6d4c41; border-bottom: 5px solid #3e2723;
    }
    .btn:active { transform: translateY(3px); border-bottom: 2px solid #3e2723; }
    .btn-video { background: #d84315; border-bottom: 5px solid #bf360c; margin-top: 10px; }

    /* CHAT BUBBLE */
    .chat { display: flex; gap: 12px; margin-top: 15px; align-items: flex-start; background: #fdf5e6; padding: 10px; border-radius: 10px; border-left: 5px solid #6d4c41; }
    .avatar { width: 60px; height: 60px; border-radius: 50%; border: 3px solid #6d4c41; object-fit: cover; background: #eee; }
    .msg { font-size: 14px; line-height: 1.4; }
    .name { font-weight: bold; display: block; color: #d84315; font-size: 12px; margin-bottom: 3px; }

    video { width: 100%; border-radius: 10px; margin-top: 15px; border: 4px solid #3e2723; background: #000; }
  </style>
</head>
<body>

<div class="container">
  <h1>☕ Warung Komedi</h1>
  <p class="subtitle">"Kopi Pahit, Script Legit"</p>

  <div class="token-box">
    <label>🔑 <strong>Token Hugging Face:</strong></label>
    <input type="password" id="hfToken" placeholder="Paste token hf_... di sini">
    <small style="font-size: 10px; display: block; margin-top: 5px;">*Token aman, tidak akan ter-upload ke GitHub.</small>
  </div>

  <div class="card">
    <label><b>Pilih Karakter Utama:</b></label>
    <select id="tema">
      <option value="bang_jali">Bang Jali (Si Sultan KW)</option>
      <option value="mang_udin">Mang Udin (Si Nasib Malang)</option>
      <option value="asep">Asep (Si Mahasiswa Filosofi)</option>
    </select>
    <button class="btn" style="margin-top: 10px;" onclick="bikinCerita()">🎯 Generate Script</button>
  </div>

  <div id="hasil" style="display:none;">
    <div class="card">
      <div id="chatDisplay"></div>
      <button class="btn btn-video" id="btnVid" onclick="renderVideo()">🎬 Render Video Gerak (AI)</button>
      <div id="videoContainer"></div>
    </div>
  </div>
</div>

<script>
  // LINK RAW DISESUAIKAN DENGAN REPO: warungkomedi
  const repoBase = "https://raw.githubusercontent.com/tetesembun05-art/warungkomedi/main/";
  
  const gambarLink = {
    'bang_jali': repoBase + 'Bang%20Jali.jpg',
    'mang_udin': repoBase + 'Mang%20Udin%20(2).jpg',
    'asep': repoBase + 'Asep.jpg'
  };

  const dialogs = {
    'bang_jali': "Woy Din! Liat nih HP gue, layarnya bisa dilipet jadi dompet!",
    'mang_udin': "HP abang bisa dilipet, saya cari uang selembar aja susah bener bang...",
    'asep': "Sebenarnya teknologi itu hanya distraksi dari ketiadaan makna diri."
  };

  let heroKarakter = '';

  function bikinCerita() {
    heroKarakter = document.getElementById('tema').value;
    const display = document.getElementById('chatDisplay');
    
    display.innerHTML = `
      <div class="chat">
        <img src="${gambarLink[heroKarakter]}" class="avatar" onerror="this.src='https://via.placeholder.com/60'">
        <div class="msg">
          <span class="name">${heroKarakter.replace('_',' ').toUpperCase()}</span>
          "${dialogs[heroKarakter]}"
        </div>
      </div>
    `;
    document.getElementById('hasil').style.display = 'block';
    document.getElementById('videoContainer').innerHTML = '';
  }

  async function renderVideo() {
    const token = document.getElementById('hfToken').value;
    if(!token) return alert("Tempel dulu token HF kamu di kotak cokelat atas!");

    const statusBtn = document.getElementById('btnVid');
    statusBtn.innerText = "⏳ AI Lagi Masak Video...";
    statusBtn.disabled = true;

    try {
      const res = await fetch("https://api-inference.huggingface.co/models/stabilityai/stable-video-diffusion-img2vid-xt", {
        headers: { Authorization: `Bearer ${token}`, "Content-Type": "application/json" },
        method: "POST",
        body: JSON.stringify({ 
            inputs: gambarLink[heroKarakter],
            parameters: { fps: 14, motion_bucket_id: 127 }
        }),
      });

      if (!res.ok) throw new Error("Gagal! Cek Token atau model sedang sibuk (Cold Start).");

      const blob = await res.blob();
      const vidUrl = URL.createObjectURL(blob);
      document.getElementById('videoContainer').innerHTML = `<video controls autoplay loop><source src="${vidUrl}"></video>`;
    } catch (err) {
      alert("Waduh: " + err.message);
    } finally {
      statusBtn.innerText = "🎬 Render Video Gerak (AI)";
      statusBtn.disabled = false;
    }
  }
</script>
</body>
</html>
